        "[ft_i]/s"^^xsd:string ;
    emmo:unitSymbol "ft/s"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Foot_per_second?oldid=491316573"^^xsd:string .

