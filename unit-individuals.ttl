    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Square Metres per second is the SI derived unit of angular momentum, defined by distance or displacement in metres multiplied by distance again in metres and divided by time in seconds. The unit is written in symbols as m2/s or m2u00b7s-1 or m2s-1. It may be better understood when phrased as "metres per second times metres", i.e. the momentum of an object with respect to a position.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/M2-PER-SEC"^^xsd:string ;
    emmo:ucumCode "m2.s-1"^^xsd:string,
        "m2/s"^^xsd:string ;
    emmo:unitSymbol "m²/s"^^xsd:string .

