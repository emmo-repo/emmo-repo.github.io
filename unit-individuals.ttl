[] a owl:Axiom ;
    owl:annotatedProperty emmo:definition ;
    owl:annotatedSource emmo:EMMO_08cb807c_e626_447b_863f_e2835540e918 ;
    owl:annotatedTarget "u ≡ σx⟨P(x, x)⟩"^^xsd:string ;
    emmo:note "This definition reads: \"The universe is the sum of all entities that are part of themselves\". Since parthood (P) is reflexive by axiom, then the universe is the sum of all mereological entities."@en .

