emmo:BtuPerPoundDegreeFahrenheit a owl:NamedIndividual,
        emmo:EMMO_08b308d4_31cd_4779_a784_aa92fc730f39,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_7cef5aae_baae_42d1_959a_ee70a7cf7a73 ;
