    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Rankine is a thermodynamic (absolute) temperature scale. The symbol for degrees Rankine is °R or °Ra if necessary to distinguish it from the Rømer and Réaumur scales). Zero on both the Kelvin and Rankine scales is absolute zero, but the Rankine degree is defined as equal to one degree Fahrenheit, rather than the one degree Celsius used by the Kelvin scale. A temperature of -459.67 °F is exactly equal to 0 °R.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/DEG_R"^^xsd:string ;
    emmo:ucumCode "[degR]"^^xsd:string ;
    emmo:unitSymbol "°R"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Rankine_scale"^^xsd:string .

