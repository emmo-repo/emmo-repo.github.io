<urn:swrl:var#z> a swrl:Variable .

emmo:Coulomb a owl:NamedIndividual,
        emmo:EMMO_ab79e92b_5377_454d_be06_d61b50db295a,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Coulomb"@en ;
    schema:unitCode "COU"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "C"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Coulomb"^^xsd:anyURI ;
    emmo:elucidation "SI unit for electric charge."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.C01365"^^xsd:string ;
    emmo:note """The SI unit of electric charge. One coulomb is the amount of charge accumulated in one second by a current of one ampere. Electricity is actually a flow of charged particles, such as electrons, protons, or ions. The charge on one of these particles is a whole-number multiple of the charge e on a single electron, and one coulomb represents a charge of approximately 6.241 506 x 1018 e. The coulomb is named for a French physicist, Charles-Augustin de Coulomb (1736-1806), who was the first to measure accurately the forces exerted between electric charges.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/C"^^xsd:string ;
    emmo:ucumCode "C"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Coulomb?oldid=491815163"^^xsd:anyURI .

emmo:EMMO_4be0acad_af05_426f_aa6d_fe7531072564 a owl:ObjectProperty ;
    rdfs:comment "Relates a prefixed unit to its metric prefix part."@en ;
    rdfs:domain emmo:EMMO_c6d4a5e0_7e95_44df_a6db_84ee0a8bbc8e ;
