emmo:Cord a owl:NamedIndividual,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_9141801c_c539_4c72_b423_8c74ff6b8f05,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Cord"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 3.62e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The cord is a unit of measure of dry volume used in Canada and the United States to measure firewood and pulpwood. A cord is the amount of wood that, when 'ranked and well stowed' (arranged so pieces are aligned, parallel, touching and compact), occupies a volume of 128 cubic feet (3.62 cubic metres). This corresponds to a well stacked woodpile 4 feet (122 cm) wide, 4 feet (122 cm) high, and 8 feet (244 cm) long; or any other arrangement of linear measurements that yields the same volume. The name cord probably comes from the use of a cord or string to measure it.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/CORD"^^xsd:string ;
    emmo:ucumCode "[crd_us]"^^xsd:string ;
    emmo:unitSymbol "cord"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Cord?oldid=490232340"^^xsd:string .

emmo:CoulombMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
