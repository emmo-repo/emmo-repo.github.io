emmo:LuxHour a owl:NamedIndividual,
        emmo:EMMO_ac19c801_bead_4730_8b8c_50020eec45ec,
        emmo:EMMO_e467cc3f_676c_432e_b70e_19237d1bcc78 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Lux Hour"@en ;
    skos:prefLabel "LuxHour"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 3.6e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The SI unit for measuring the illumination (illuminance) of a surface. One lux is defined as an illumination of one lumen per square meter or 0.0001 phot. In considering the various light units, it's useful to think about light originating at a point and shining upon a surface. The intensity of the light source is measured in candelas; the total light flux in transit is measured in lumens (1 lumen = 1 candelau00b7steradian); and the amount of light received per unit of surface area is measured in lux (1 lux = 1 lumen/square meter). One lux is equal to approximately 0.09290 foot candle.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/LUX-HR"^^xsd:string ;
    emmo:ucumCode "lx.h"^^xsd:string ;
    emmo:unitSymbol "lx⋅h"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Lux?oldid=494700274"^^xsd:string .

