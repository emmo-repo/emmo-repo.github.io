    skos:prefLabel "CausalParticle"@en ;
    emmo:OWLRL2DLAxioms "EquivalentTo: CausalPath or Quantum"^^xsd:string ;
    emmo:conceptualisation "A causal particle represents the most elementary entity in physics, being it a simple state of an elementary particle, called quantum in the EMMO, or a chain of causally connected quanta."@en ;
    emmo:definition "The disjoint union of CausalPath and Quantum classes."@en ;
    emmo:elucidation "The class of individuals representing causal particles."@en .

