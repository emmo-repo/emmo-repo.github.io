emmo:Barad a owl:NamedIndividual,
        emmo:EMMO_53bd0c90_41c3_46e2_8779_cd2a80f7e18b,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Barad"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e-01 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A barad is a dyne per square centimetre (dyn · cm⁻²), and is equal to 0.1 Pa  (1   micro   bar, 0.000014504   p.s.i.). Note that this is precisely the microbar, the confusable bar being related in size to the normal atmospheric pressure, at 100 dyn · cm⁻². Accordingly barad was not abbreviated, so occurs prefixed as in cbarad = centibarad. Despite being the coherent unit for pressure in c.g.s., barad was probably much less common than the non-coherent bar. Barad is sometimes called barye, a name also used for bar.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/BARAD"^^xsd:string ;
    emmo:unitSymbol "Ba"^^xsd:string .

