emmo:Gray a owl:NamedIndividual,
        emmo:EMMO_847f1d9f_205e_46c1_8cb6_a9e479421f88,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Gray"@en ;
    schema:unitCode "A95"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Gy"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Grey"^^xsd:anyURI ;
    emmo:elucidation "SI unit for absorbed dose."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.G02696"^^xsd:string ;
    emmo:note """The SI unit of radiation dose. Radiation carries energy, and when it is absorbed by matter the matter receives this energy. The dose is the amount of energy deposited per unit of mass. One gray is defined to be the dose of one joule of energy absorbed per kilogram of matter, or 100 rad. The unit is named for the British physician L. Harold Gray (1905-1965), an authority on the use of radiation in the treatment of cancer.

-- QUDT"""^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/GRAY"^^xsd:string ;
    emmo:ucumCode "Gy"^^xsd:string ;
    emmo:wikipediaReference "//en.wikipedia.org/wiki/Grey?oldid=494774160"^^xsd:anyURI .

emmo:HertzMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_4f5c7c54_1c63_4d17_b12b_ea0792c2b187 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Hertz Metre"@en ;
    skos:prefLabel "HertzMetre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """product of the SI derived unit hertz and the SI base unit metre

-- QUDT"""@en ;
