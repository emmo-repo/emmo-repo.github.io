    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#> ;
    skos:prefLabel "KiloBar"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+08 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:EMMO_d4e0a0ab_2f67_4f87_a0db_b544e6dceed4 emmo:Bar ;
    emmo:elucidation """The bar is a non-SI unit of pressure, defined by the IUPAC as exactly equal to 100,000 Pa. It is about equal to the atmospheric pressure on Earth at sea level, and since 1982 the IUPAC has recommended that the standard for atmospheric pressure should be harmonized to 100,000 Pa = 1 bar ≈ 750.0616827 Torr. Units derived from the bar are the megabar (symbol: Mbar), kilobar (symbol: kbar), decibar (symbol: dbar), centibar (symbol: cbar), and millibar (symbol: mbar or mb). They are not SI or cgs units, but they are accepted for use with the SI.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/KiloBAR"^^xsd:string ;
    emmo:ucumCode "kbar"^^xsd:string ;
    emmo:unitSymbol "kbar"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Bar_(unit)"^^xsd:string .

