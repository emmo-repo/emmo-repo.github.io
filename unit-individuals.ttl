emmo:NewtonMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_f6070071_d054_4b17_9d2d_f446f7147d0f ;
    rdfs:comment "Note that the physical dimension is the same as for Joule."@en ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#> ;
    skos:prefLabel "NewtonMetre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """"Torque" is the tendency of a force to cause a rotation, is the product of the force and the distance from the center of rotation to the point where the force is applied. Torque has the same units as work or energy, but it is a different physical concept. To stress the difference, scientists measure torque in newton meters rather than in joules, the SI unit of work. One newton meter is approximately 0.737562 pound foot.

-- QUDT"""@en ;
    emmo:omReference "http://www.ontology-of-units-of-measure.org/resource/om-2/newtonMetre"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/N-M"^^xsd:string ;
    emmo:unitSymbol "N⋅m"^^xsd:string .

emmo:Second a owl:NamedIndividual,
        emmo:EMMO_02e894c3_b793_4197_b120_3442e08f58d1,
        emmo:EMMO_3a185e6c_9e19_4776_b583_19c978156aa0 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Second"@en ;
    schema:unitCode "SEC"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "s"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Second"^^xsd:anyURI ;
    emmo:definition "The second, symbol s, is the SI unit of time. It is defined by taking the fixed numerical value of the caesium frequency ∆νCs, the unperturbed ground-state hyperfine transition frequency of the caesium 133 atom, to be 9192631770 when expressed in the unit Hz, which is equal to s−1."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.S05513"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/SEC"^^xsd:string ;
    emmo:ucumCode "s"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Second?oldid=495241006"^^xsd:anyURI .

emmo:metrologyReference a owl:AnnotationProperty ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/metrology#> ;
    rdfs:subPropertyOf rdfs:seeAlso ;
    skos:prefLabel "metrologyReference"@en .

emmo:Bar a owl:NamedIndividual,
        emmo:EMMO_53bd0c90_41c3_46e2_8779_cd2a80f7e18b,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Bar"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+05 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The bar is a non-SI unit of pressure, defined by the IUPAC as exactly equal to 100,000 Pa. It is about equal to the atmospheric pressure on Earth at sea level, and since 1982 the IUPAC has recommended that the standard for atmospheric pressure should be harmonized to 100,000 Pa = 1  bar ≈ 750.0616827  Torr. Units derived from the bar are the megabar (symbol: Mbar), kilobar (symbol: kbar), decibar (symbol: dbar), centibar (symbol: cbar), and millibar (symbol: mbar or mb). They are not SI or cgs units, but they are accepted for use with the SI.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/BAR"^^xsd:string ;
    emmo:ucumCode "bar"^^xsd:string ;
    emmo:unitSymbol "bar"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Bar_(unit)"^^xsd:string .

emmo:Becquerel a owl:NamedIndividual,
        emmo:EMMO_515b5579_d526_4842_9e6f_ecc34db6f368,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Becquerel"@en ;
    schema:unitCode "BQL"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Bq"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Becquerel"^^xsd:anyURI ;
    emmo:definition "Radioactive decays per second."@en ;
    emmo:elucidation "SI unit for radioactive activity."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.B00624"^^xsd:string ;
    emmo:note """The SI derived unit of activity, usually meaning radioactivity. "Radioactivity" is caused when atoms disintegrate, ejecting energetic particles. One becquerel is the radiation caused by one disintegration per second; this is equivalent to about 27.0270 picocuries (pCi). The unit is named for a French physicist, Antoine-Henri Becquerel (1852-1908), the discoverer of radioactivity. Note: both the becquerel and the hertz are basically defined as one event per second, yet they measure different things. The hertz is used to measure the rates of events that happen periodically in a fixed and definite cycle. The becquerel is used to measure the rates of events that happen sporadically and unpredictably, not in a definite cycle.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/BQ"^^xsd:string ;
    emmo:ucumCode "Bq"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Becquerel?oldid=493710036"^^xsd:anyURI .

emmo:EMMO_0f795e3e_c602_4577_9a43_d5a231aa1360 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/foundation/mereocausality#> ;
    rdfs:subClassOf _:214,
        emmo:EMMO_52b8a39b_e5ff_46d3_b972_65bc43077a07,
        emmo:EMMO_c5ddfdba_c074_4aa4_ad6b_1ac4942d300d ;
    skos:altLabel "CausalChain"@en,
        "Elementary"@en ;
    skos:example "An electron moving in time interacting with other particles."@en ;
    skos:prefLabel "CausalPath"@en ;
    emmo:conceptualisation "A causal chain is an ordered causal sequence of entities that does not host any bifurcation within itself (a chain). A chain can only be partitioned in time."@en ;
    emmo:elucidation "The class of entities that possess a temporal structure but no spatial structure."@en ;
    emmo:note "A causal path is a concept almost equivalent to the concept of elementary particle in physics."@en .

emmo:EMMO_10a5fd39_06aa_4648_9e70_f962a9cb2069 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/perspectives/semiotics#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_9e3ad976_b179_4315_b51e_7e874df583dc ;
            owl:someValuesFrom emmo:EMMO_b7bcff25_ffc3_474e_9ab5_01b1664bd4ba ],
        [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_cb804456_9459_4be5_ac63_a291a872fbd0 ;
            owl:someValuesFrom emmo:EMMO_1b52ee70_121e_4d8d_8419_3f97cd0bd89c ],
        emmo:EMMO_47bf3513_4ae6_4858_9c45_76e23230d68d ;
    skos:altLabel "Characterisation"@en ;
    skos:example "Assigning the word \"red\" as sign for an object provides an information to all other interpreters about the outcome of a specific observation procedure according to the determiner."@en ;
    skos:prefLabel "Determination"@en ;
    emmo:OWLRL2DLAxioms "EquivalentTo: Estimation or Observation"^^xsd:string ;
    emmo:elucidation "A 'Semiosis' that involves an 'Observer' that perceives another 'Physical' (the 'Object') through a specific perception mechanism and produces a 'Property' (the 'Sign') that stands for the result of that particular perception according to a well defined conventional procedure."@en .

emmo:EMMO_216f448e_cdbc_4aeb_a529_7a5fe7fc38bb a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/metrology#> ;
    rdfs:subClassOf emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( emmo:EMMO_a1083d0a_c1fb_471f_8e20_a98f881ad527 emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ) ] ;
    skos:example "Some examples are \"Pa\", \"m\" and \"J\"."@en ;
    skos:prefLabel "UnitSymbol"@en ;
    emmo:OWLRL2DLAxioms "DisjointUnionOf: SpecialUnit, BaseUnit"^^xsd:string ;
    emmo:elucidation "A symbol that stands for a single unit."@en .

emmo:EMMO_3733bd38_ca2b_4264_a92a_3075a1715598 a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:isDefinedBy <https://w3id.org/emmo/foundation/mereocausality#> ;
    rdfs:seeAlso emmo:EMMO_451e410e_8e0d_4a4b_9211_d6ef619296dc ;
    rdfs:subPropertyOf emmo:EMMO_b85e4738_500c_4e1b_bbe8_9e84190485d6,
        emmo:EMMO_ebc9e62c_5dc4_44db_9060_7923740bdf78 ;
    owl:inverseOf emmo:EMMO_451e410e_8e0d_4a4b_9211_d6ef619296dc ;
    owl:propertyDisjointWith emmo:EMMO_d01b3ee2_91a5_4ce2_95cd_f0d2c333c6d3 ;
    skos:altLabel "hasSuccessor"@en,
        "isAntecedentOf"@en,
        "predecessorOf"@en ;
    skos:example "My life between 18-24 years has successor my life between 32-40 years, since there is an intermediary (i.e. my life between 25-32 years)."@en ;
    skos:prefLabel "foreruns"@en ;
    emmo:elucidation "A causal relation between the y effected and the x causing entities with intermediaries, where x isCauseOf y and not(y isCauseOf x)."@en ;
    emmo:note "Transitivity is implemented at A-Box level with a SWRL rule."@en .

emmo:EMMO_3ecff38b_b3cf_4a78_b49f_8580abf8715b a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/sidimensionalunits#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "T-2 L+2 M+1 I0 Θ-1 N0 J0"^^xsd:string ;
            owl:onProperty emmo:EMMO_19d925d0_2cf1_40e5_a391_1a99d68409c9 ],
        emmo:EMMO_9895a1b4_f0a5_4167_ac5e_97db40b8bfcc ;
    skos:prefLabel "EntropyUnit"@en ;
    emmo:elucidation "The class of units with dimensionality 'Entropy'."@en .

emmo:EMMO_3f9ae00e_810c_4518_aec2_7200e424cf68 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/foundation/mereocausality#> ;
    rdfs:subClassOf emmo:EMMO_52b8a39b_e5ff_46d3_b972_65bc43077a07 ;
    owl:disjointWith emmo:EMMO_53ed8611_2cd7_4286_9ef0_36572117b963 ;
    skos:altLabel "RealParticle"@en ;
    skos:example """From a physics perspective a quantum can be related to smallest identifiable entities, according to the limits imposed by the uncertainty principle in space and time measurements.
However, the quantum mereotopology approach is not restricted only to physics. For example, in a manpower management ontology, a quantum can stand for an hour (time) of a worker (space) activity."""@en ;
    skos:prefLabel "Quantum"@en ;
    emmo:conceptualisation """A quantum is the most fundamental item of the EMMO (both mereologically and causally) and is considered causally self-connected by definition.
The quantum concept recalls the fact that there is lower epistemological limit to our knowledge of the universe, related to the uncertainity principle.
In the EMMO, space and time emerge following the network of causal connections between quantum objects. So quantum objects are adimensional objects, that precede space and time dimensions: they are simple beings (in greek οντα).
Using physics concepts, we can think the quantum as an elementary particle (e.g. an electron) in a specific state between two causal interactions. For a quanta to change its state, it requires an interaction.
A quantum may be thought as standing for an incoming or outcoming real particle in a Feynman diagram in a scattering event."""@en ;
    emmo:definition "Q(x) ≡ ¬∃y(PP(y,x))"@en ;
    emmo:elucidation "The class of the mereological and causal fundamental entities having no proper parts"@en ;
    emmo:note "A quantum is the EMMO mereological atomistic and causal reductionistic entity.  To avoid confusion with the concept of atom coming from physics and to underline the causal reductionistic approach, we will use the expression quantum mereology, instead of atomistic mereology."@en .

emmo:EMMO_43e499a1_ca67_4380_ac08_cfc52a93ad04 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/sidimensionalunits#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "T-1 L-3 M0 I0 Θ0 N0 J0"^^xsd:string ;
            owl:onProperty emmo:EMMO_19d925d0_2cf1_40e5_a391_1a99d68409c9 ],
        emmo:EMMO_9895a1b4_f0a5_4167_ac5e_97db40b8bfcc ;
    skos:prefLabel "FrequencyPerVolumeUnit"@en ;
    emmo:elucidation "The class of units with dimensionality 'FrequencyPerVolume'."@en .

