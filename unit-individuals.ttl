emmo:MegaTonOfOilEquivalent a owl:NamedIndividual,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4,
        emmo:EMMO_c6d4a5e0_7e95_44df_a6db_84ee0a8bbc8e,
        emmo:EMMO_f6070071_d054_4b17_9d2d_f446f7147d0f ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/unclassifiedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Megaton of Oil Equivalent"@en ;
    skos:prefLabel "MegaTonOfOilEquivalent"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 4.1868e+16 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The tonne of oil equivalent (toe) is a unit of energy: the amount of energy released by burning one tonne of crude oil, approximately 42 GJ (as different crude oils have different calorific values, the exact value of the toe is defined by convention; unfortunately there are several slightly different definitions as discussed below). The toe is sometimes used for large amounts of energy, as it can be more intuitive to visualise, say, the energy released by burning 1000 tonnes of oil than 42,000 billion joules (the SI unit of energy).
Multiples of the toe are used, in particular the megatoe (Mtoe, one million toe) and the gigatoe (Gtoe, one billion toe).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MegaTOE"^^xsd:string ;
    emmo:unitSymbol "megatoe"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Tonne_of_oil_equivalent"^^xsd:string .

