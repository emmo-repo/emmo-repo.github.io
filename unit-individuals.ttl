    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """SI derived unit joule divided by the SI base unit second

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/J-PER-SEC"^^xsd:string ;
    emmo:ucumCode "J.s-1"^^xsd:string ;
    emmo:unitSymbol "J/s"^^xsd:string .

