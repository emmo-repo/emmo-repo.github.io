    rdfs:subPropertyOf emmo:EMMO_ec2472ae_cf4a_46a5_8555_1556f5a6c3c5 ;
    skos:prefLabel "semiotical"@en ;
    emmo:elucidation "The generic EMMO semiotical relation."@en .

