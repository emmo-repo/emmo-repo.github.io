emmo:Biot a owl:NamedIndividual,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_d5f3e0e5_fc7d_4e64_86ad_555e74aaff84,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    rdfs:seeAlso "http://www.translatorscafe.com/cafe/EN/units-converter/current/10-4/"^^xsd:string ;
    skos:prefLabel "Biot"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+01 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """"Biot" is another name for the abampere (aA), which is the basic electromagnetic unit of electric current in the emu-cgs (centimeter-gram-second) system of units. It is called after a French physicist, astronomer, and mathematician Jean-Baptiste Biot. One abampere is equal to ten amperes in the SI system of units. One abampere is the current, which produces a force of 2 dyne/cm between two infinitively long parallel wires that are 1 cm apart.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/BIOT"^^xsd:string ;
    emmo:ucumCode "Bi"^^xsd:string ;
    emmo:unitSymbol "Bi"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Biot?oldid=443318821"^^xsd:string .

