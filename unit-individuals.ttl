emmo:EMMO_8bb6b688_812a_4cb9_b76c_d5a058928719 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/perspectives/semiotics#> ;
    rdfs:seeAlso "https://plato.stanford.edu/entries/peirce-semiotics/"^^xsd:anyURI,
