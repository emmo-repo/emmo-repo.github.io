emmo:KiloCaloriePerMole a owl:NamedIndividual,
        emmo:EMMO_0972cb08_48bd_4524_ac03_8a2e7f30f02f,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
