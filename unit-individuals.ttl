emmo:MileUsStatute a owl:NamedIndividual,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4,
        emmo:EMMO_b3600e73_3e05_479d_9714_c041c3acf5cc ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/unclassifiedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Mile US Statute"@en ;
    skos:prefLabel "MileUsStatute"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.609347e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The exact length of the land mile varied slightly among English-speaking countries until the international yard and pound agreement in 1959 established the yard as exactly 0.9144 metres, giving a mile of exactly 1,609.344 metres. The United States adopted this international mile for most purposes, but retained the pre-1959 mile for some land-survey data, terming it the US survey mile. In the US, statute mile formally refers to the survey mile, about 3.219 mm (1/8 inch) longer than the international mile (the international mile is exactly 0.0002% less than the US survey mile).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MI_US"^^xsd:string ;
    emmo:ucumCode "[mi_us]"^^xsd:string ;
    emmo:unitSymbol "mi{US}"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Mile"^^xsd:string .

