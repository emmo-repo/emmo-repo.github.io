    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Metre per hour is a metric unit of both speed (scalar) and velocity (Vector (geometry)). Its symbol is m/h or mu00b7h-1 (not to be confused with the imperial unit symbol mph. By definition, an object travelling at a speed of 1 m/h for an hour would move 1 metre.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/M-PER-HR"^^xsd:string ;
    emmo:ucumCode "m.h-1"^^xsd:string,
        "m/h"^^xsd:string ;
    emmo:unitSymbol "m/h"^^xsd:string .

emmo:MetrePerSecond a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_4f5c7c54_1c63_4d17_b12b_ea0792c2b187 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#> ;
    skos:prefLabel "MetrePerSecond"@en ;
    schema:unitCode "MTS"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Metre per second is an SI derived unit of both speed (scalar) and velocity (vector quantity which specifies both magnitude and a specific direction), defined by distance in metres divided by time in seconds.
The official SI symbolic abbreviation is mu00b7s-1, or equivalently either m/s.

-- QUDT"""@en ;
    emmo:omReference "http://www.ontology-of-units-of-measure.org/resource/om-2/metrePerSecond-Time"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/M-PER-SEC"^^xsd:string ;
    emmo:ucumCode "m.s-1"^^xsd:string ;
    emmo:unitSymbol "m/s"^^xsd:string .

