emmo:Fathom a owl:NamedIndividual,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4,
        emmo:EMMO_b3600e73_3e05_479d_9714_c041c3acf5cc ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/unclassifiedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Fathom"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.8288e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A fathom = 1.8288 meters, is a unit of length in the imperial and the U.S. customary systems, used especially for measuring the depth of water. There are two yards in an imperial or U.S. fathom. Originally based on the distance between the man's outstretched arms, the size of a fathom has varied slightly depending on whether it was defined as a thousandth of an (Admiralty) nautical mile or as a multiple of the imperial yard.  Abbreviations: f, fath, fm, fth, fthm.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/FATH"^^xsd:string ;
    emmo:ucumCode "[fth_i]"^^xsd:string ;
    emmo:unitSymbol "fathom"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Fathom?oldid=493265429"^^xsd:string .

