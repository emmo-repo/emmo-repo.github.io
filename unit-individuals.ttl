        emmo:EMMO_9895a1b4_f0a5_4167_ac5e_97db40b8bfcc ;
    skos:prefLabel "ElectricCurrentPerMassUnit"@en ;
    emmo:elucidation "The class of units with dimensionality 'ElectricCurrentPerMass'."@en .

