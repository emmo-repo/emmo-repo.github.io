emmo:Lumen a owl:NamedIndividual,
        emmo:EMMO_14ff4393_0f28_4fb4_abc7_c2cc00bc761d,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Lumen"@en ;
    schema:unitCode "LUM"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "lm"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Lumen"^^xsd:anyURI ;
    emmo:elucidation "SI unit for luminous flux."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.L03639"^^xsd:string ;
    emmo:note """The SI unit for measuring the flux of light being produced by a light source or received by a surface. The intensity of a light source is measured in candelas. One lumen represents the total flux of light emitted, equal to the intensity in candelas multiplied by the solid angle in steradians into which the light is emitted. A full sphere has a solid angle of 4·π steradians. A light source that uniformly radiates one candela in all directions has a total luminous flux of 1 cd·4π sr = 4π cd·sr ≈ 12.57 lumens. "Lumen" is a Latin word for light.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/LM"^^xsd:string ;
    emmo:ucumCode "lm"^^xsd:string ;
    emmo:wikipediaReference "https://en.wikipedia.org/wiki/Lumen_(unit)"^^xsd:anyURI .

emmo:Lux a owl:NamedIndividual,
        emmo:EMMO_4000d06d_8594_4263_ba72_5d9440b66c5e,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Lux"@en ;
    schema:unitCode "LUX"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "lx"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Lux"^^xsd:anyURI ;
    emmo:elucidation "SI unit for illuminance."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.L03651"^^xsd:string ;
    emmo:note """The SI unit for measuring the illumination (illuminance) of a surface. One lux is defined as an illumination of one lumen per square meter or 0.0001 phot. In considering the various light units, it's useful to think about light originating at a point and shining upon a surface. The intensity of the light source is measured in candelas; the total light flux in transit is measured in lumens (1 lumen = 1 candelau·steradian); and the amount of light received per unit of surface area is measured in lux (1 lux = 1 lumen/square meter). One lux is equal to approximately 0.09290 foot candle.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/LUX"^^xsd:string ;
    emmo:ucumCode "lx"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Lux?oldid=494700274"^^xsd:anyURI .

