    emmo:ucumCode "N.m-2"^^xsd:string ;
    emmo:unitSymbol "N/m²"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Pascal?oldid=492989202"^^xsd:string .

