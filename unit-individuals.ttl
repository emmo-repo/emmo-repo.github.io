    skos:prefLabel "CoulombMetre"@en ;
    schema:unitCode "A26"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Coulomb Meter (C-m) is a unit in the category of Electric dipole moment. It is also known as atomic unit, u.a., au, ua. This unit is commonly used in the SI unit system. Coulomb Meter (C-m) has a dimension of LTI where L is length, T is time, and I is electric current. This unit is the standard SI unit in this category.

-- QUDT"""@en ;
    emmo:note "It is also known as atomic unit, u.a., au, ua. This unit is commonly used in the SI unit system. Coulomb Meter (C-m) has a dimension of LTI where L is length, T is time, and I is electric current. This unit is the standard SI unit in this category."^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/C-M"^^xsd:anyURI ;
    emmo:ucumCode "C.m"^^xsd:string ;
    emmo:unitSymbol "C⋅m"^^xsd:string .

