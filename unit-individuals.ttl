emmo:PascalSecondPerCubicMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_9cffc70d_4b60_4187_a7cd_706f5740ae87 ;
