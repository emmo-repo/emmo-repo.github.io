    skos:prefLabel "RadianPerMinute"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 6e+01 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Radian Per Minute (rad/min) is a unit in the category of Angular velocity. It is also known as radians per minute, radian/minute. Radian Per Minute (rad/min) has a dimension of aT-1 where T is time. It can be converted to the corresponding standard SI unit rad/s by multiplying its value by a factor of 0.0166666666667.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/RAD-PER-MIN"^^xsd:string ;
    emmo:ucumCode "rad.min-1"^^xsd:string,
        "rad/min"^^xsd:string ;
    emmo:unitSymbol "rad/min"^^xsd:string .

emmo:RadianPerSecond a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_515b5579_d526_4842_9e6f_ecc34db6f368 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "radian per second"@en ;
    skos:prefLabel "RadianPerSecond"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """"Radian per Second" is the SI unit of rotational speed (angular velocity), and, also the unit of angular frequency. The radian per second is defined as the change in the orientation of an object, in radians, every second.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/RAD-PER-SEC"^^xsd:string ;
    emmo:ucumCode "rad.s-1"^^xsd:string,
        "rad/s"^^xsd:string ;
    emmo:unitSymbol "rad/s"^^xsd:string .

