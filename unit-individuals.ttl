        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Planck Momentum"@en ;
    skos:prefLabel "PlanckMomentum"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 6.52485e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Planck momentum is the unit of momentum in the system of natural units known as Planck units. It has no commonly used symbol of its own, but can be denoted by, where is the Planck mass and is the speed of light in a vacuum. Then where is the reduced Planck's constant, is the Planck length, is the gravitational constant. In SI units Planck momentum is ≈ 6.5 kg m/s.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/PlanckMomentum"^^xsd:string ;
    emmo:unitSymbol "planckmomentum"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Planck_momentum?oldid=493644981"^^xsd:string .

emmo:PlanckPower a owl:NamedIndividual,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
