emmo:AmpereTurn a owl:NamedIndividual,
        emmo:EMMO_08b308d4_31cd_4779_a784_aa92fc730f39,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_d5f3e0e5_fc7d_4e64_86ad_555e74aaff84 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Ampere Turn"@en ;
    skos:prefLabel "AmpereTurn"@en ;
    emmo:elucidation """The `ampere-turn` was the MKS unit of magnetomotive force (MMF), represented by a direct current of one ampere flowing in a single-turn loop in a vacuum. "Turns" refers to the winding number of an electrical conductor comprising an inductor. The ampere-turn was replaced by the SI unit, ampere.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/AT"^^xsd:string ;
    emmo:unitSymbol "AT"^^xsd:string .

emmo:AmpereTurnPerInch a owl:NamedIndividual,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_e6b83139_ba92_4fbd_a8b2_c8dde55844a1 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#>,
