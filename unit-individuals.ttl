emmo:Dalton a owl:NamedIndividual,
        emmo:EMMO_6795a4b8_ffd0_4588_a581_a9413fe49cac,
        emmo:EMMO_77e9dc31_5b19_463e_b000_44c6e79f98aa ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedspecialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "AtomicMassUnit"@en ;
    skos:prefLabel "Dalton"@en ;
    schema:unitCode "D43"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.660539e-27 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Da"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/page/Unified_atomic_mass_unit"^^xsd:string ;
    emmo:definition "One dalton is defined as one twelfth of the mass of an unbound neutral atom of carbon-12 in its nuclear and electronic ground state."@en ;
    emmo:elucidation """The unified atomic mass unit (symbol: μ) or dalton (symbol: Da) is a unit that is used for indicating mass on an atomic or molecular scale. It is defined as one twelfth of the rest mass of an unbound atom of carbon-12 in its nuclear and electronic ground state, and has a value of 1.660538782(83) × 10⁻²⁷ kg. One Da is approximately equal to the mass of one proton or one neutron. The CIPM have categorised it as a "non-SI unit whose values in SI units must be obtained experimentally".

-- QUDT"""@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.D01514"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/Da"^^xsd:anyURI ;
    emmo:ucumCode "u"^^xsd:string ;
    emmo:unitSymbol "amu"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Atomic_mass_unit"^^xsd:anyURI .

