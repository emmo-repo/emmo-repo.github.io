    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """product of the SI derived unit volt and the SI base unit second divided by the SI base unit metre

-- QUDT"""@en ;
