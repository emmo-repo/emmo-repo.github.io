emmo:EMMO_52b8a39b_e5ff_46d3_b972_65bc43077a07 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/foundation/mereocausality#> ;
    rdfs:subClassOf emmo:EMMO_eb3a768e_d53e_4be9_a23b_0714833c36de ;
