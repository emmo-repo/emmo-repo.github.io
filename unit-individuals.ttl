    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """SI derived unit siemens divided by the SI base unit metre.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/S-PER-M"^^xsd:string ;
    emmo:ucumCode "S.m-1"^^xsd:string,
        "S/m"^^xsd:string ;
    emmo:unitSymbol "S/m"^^xsd:string .

emmo:Ampere a owl:NamedIndividual,
        emmo:EMMO_3a185e6c_9e19_4776_b583_19c978156aa0,
        emmo:EMMO_d5f3e0e5_fc7d_4e64_86ad_555e74aaff84 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Ampere"@en ;
    schema:unitCode "AMP"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "A"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Ampere"^^xsd:anyURI ;
    emmo:definition "The ampere, symbol A, is the SI unit of electric current. It is defined by taking the fixed numerical value of the elementary charge e to be 1.602176634×10−19 when expressed in the unit C, which is equal to A s, where the second is defined in terms of ∆νCs."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.A00300"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/A"^^xsd:string ;
    emmo:ucumCode "A"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Ampere?oldid=494026699"^^xsd:anyURI .

