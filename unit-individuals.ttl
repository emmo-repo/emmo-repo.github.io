emmo:Hour a owl:NamedIndividual,
        emmo:EMMO_02e894c3_b793_4197_b120_3442e08f58d1,
        emmo:EMMO_6795a4b8_ffd0_4588_a581_a9413fe49cac ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedspecialunits-abox#> ;
    skos:prefLabel "Hour"@en ;
    schema:unitCode "HUR"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 3.6e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "h"^^xsd:string ;
    emmo:definition "Measure of time defined as 3600 seconds."@en ;
    emmo:elucidation """The hour (common symbol: h or hr) is a unit of measurement of time. In modern usage, an hour comprises 60 minutes, or 3,600 seconds. It is approximately 1/24 of a mean solar day. An hour in the Universal Coordinated Time (UTC) time standard can include a negative or positive leap second, and may therefore have a duration of 3,599 or 3,601 seconds for adjustment purposes. Although it is not a standard defined by the International System of Units, the hour is a unit accepted for use with SI, represented by the symbol h.

-- QUDT"""@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.H02866"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/HR"^^xsd:string ;
    emmo:ucumCode "h"^^xsd:string .

