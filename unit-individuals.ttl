emmo:FootPerSecond a owl:NamedIndividual,
        emmo:EMMO_4f5c7c54_1c63_4d17_b12b_ea0792c2b187,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
