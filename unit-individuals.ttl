    skos:prefLabel "hasTask"@en ;
    emmo:conceptualisation "The holistic relation connecting a workflow with one of its tasks."@en .

emmo:EMMO_76bd5e44_bf5a_49f9_a517_eea5e8bcbc2d a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/foundation/mereocausality#> ;
    rdfs:subClassOf emmo:EMMO_53ed8611_2cd7_4286_9ef0_36572117b963 ;
    skos:prefLabel "CausalCluster"@en ;
    emmo:OWLRL2DLAxioms "EquivalentTo: Collection or CausalSystem"^^xsd:string ;
    emmo:conceptualisation "With the causal cluster term we address an heterogeneous group of entities, which possess the common feature of having at least two causally non connected quanta. It comprises collections (non self-connected entities) and causal systems (entities extended in space)."@en ;
    emmo:definition "The disjoint union of the CausalSystem and Collection classes."@en ;
    emmo:elucidation "The class of individuals representing causal clusters."@en .

