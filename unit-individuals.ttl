emmo:BecquerelPerKilogram a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_52b029aa_e525_4907_95d8_759298b04f97 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    rdfs:seeAlso "http://www.efunda.com/glossary/units/units--specific_radioactivity--becquerel_per_kilogram.cfm"^^xsd:string ;
    skos:altLabel "Becquerel per Kilogram"@en ;
    skos:prefLabel "BecquerelPerKilogram"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """"Becquerel per Kilogram" is used to describe radioactivity, which is often expressed in becquerels per unit of volume or weight, to express how much radioactive material is contained in a sample.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/BQ-PER-KiloGM"^^xsd:string ;
    emmo:ucumCode "Bq.kg-1"^^xsd:string,
        "Bq/kg"^^xsd:string ;
    emmo:unitSymbol "Bq/kg"^^xsd:string .

emmo:Curie a owl:NamedIndividual,
        emmo:EMMO_515b5579_d526_4842_9e6f_ecc34db6f368,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Curie"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 3.7e+10 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The curie (symbol Ci) is a non-SI unit of radioactivity, named after Marie and Pierre Curie. It is defined as 1Ci = 3.7 × 10¹⁰ decays per second Its continued use is discouraged. One Curie is roughly the activity of 1 gram of the radium isotope Ra, a substance studied by the Curies. The SI derived unit of radioactivity is the becquerel (Bq), which equates to one decay per second. Therefore: 1Ci = 3.7 × 10¹⁰ Bq= 37 GBq and 1Bq ≡ 2.703 × 10⁻¹¹Ci .

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/Ci"^^xsd:string ;
    emmo:ucumCode "Ci"^^xsd:string ;
    emmo:unitSymbol "Ci"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Curie?oldid=495080313"^^xsd:string .

emmo:DegreeCelsius a owl:NamedIndividual,
        emmo:EMMO_a77a0a4b_6bd2_42b2_be27_4b63cebbb59e,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "DegreeCelsius"@en ;
    schema:unitCode "CEL"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd -2.7315e+02 ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "°C"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Celsius"^^xsd:anyURI ;
    emmo:elucidation "Measurement unit for Celsius temperature. This unit can only be used for expressing temperature differences."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.D01561"^^xsd:string ;
    emmo:note """Celsius, also known as centigrade, is a scale and unit of measurement for temperature. It can refer to a specific temperature on the Celsius scale as well as a unit to indicate a temperature interval, a difference between two temperatures or an uncertainty. This definition fixes the magnitude of both the degree Celsius and the kelvin as precisely 1 part in 273.16 (approximately 0.00366) of the difference between absolute zero and the triple point of water. Thus, it sets the magnitude of one degree Celsius and that of one kelvin as exactly the same. Additionally, it establishes the difference between the two scales' null points as being precisely 273.15 °C.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/DEG_C"^^xsd:string ;
    emmo:ucumCode "Cel"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Celsius?oldid=494152178"^^xsd:anyURI .

