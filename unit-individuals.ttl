        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/unclassifiedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Long Ton per Cubic Yard"@en ;
    skos:prefLabel "LongTonPerCubicYard"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.328939e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The long ton per cubic yard density measurement unit is used to measure volume in cubic yards in order to estimate weight or mass in long tons.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/TON_LONG-PER-YD3"^^xsd:string ;
    emmo:ucumCode "[lton_av]/[cyd_i]"^^xsd:string ;
    emmo:unitSymbol "t{long}/yd³"^^xsd:string .

