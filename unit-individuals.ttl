    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """`Ampere Per Square Meter` is a unit in the category of electric current density. This unit is commonly used in the SI unit system.

-- QUDT"""@en ;
