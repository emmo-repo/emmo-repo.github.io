    emmo:note "This relation is used to specify the detailed information that make up the overall description for an entity. A description can be used to summarize in one single entiity several properties relaterd to the same referent."@en .

emmo:EMMO_662c64e7_fc72_49b3_a161_f50fd42deafa a owl:ObjectProperty ;
    rdfs:domain emmo:EMMO_dd4a7f3e_ef56_466c_ac1a_d2716b5f87ec ;
