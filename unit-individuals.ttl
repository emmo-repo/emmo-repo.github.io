emmo:EarthMass a owl:NamedIndividual,
        emmo:EMMO_77e9dc31_5b19_463e_b000_44c6e79f98aa,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Earth mass"@en ;
    skos:prefLabel "EarthMass"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 5.97219e+24 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Earth mass (M⊕) is the unit of mass equal to that of the Earth. In SI Units, 1 M⊕ = 5.9722 × 10²⁴ kg. Earth mass is often used to describe masses of rocky terrestrial planets. The four terrestrial planets of the Solar System, Mercury, Venus, Earth, and Mars, have masses of 0.055, 0.815, 1.000, and 0.107 Earth masses respectively.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/EarthMass"^^xsd:string ;
    emmo:unitSymbol "M⊕"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Earth_mass?oldid=495457885"^^xsd:string .

