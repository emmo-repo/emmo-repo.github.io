emmo:Shake a owl:NamedIndividual,
        emmo:EMMO_02e894c3_b793_4197_b120_3442e08f58d1,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/unclassifiedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Shake"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e-08 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A shake is an informal unit of time equal to 10 nanoseconds. It has applications in nuclear physics, helping to conveniently express the timing of various events in a nuclear explosion. The typical time required for one step in the chain reaction (i.e. the typical time for each neutron to cause a fission event which releases more neutrons) is of order 1 shake, and the chain reaction is typically complete by 50 to 100 shakes.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/SH"^^xsd:string ;
    emmo:ucumCode "10.ns"^^xsd:string ;
    emmo:unitSymbol "shake"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Shake?oldid=494796779"^^xsd:string .

