    emmo:elucidation "The class of units with dimensionality 'PowerPerAreaVolume'."@en .

emmo:EMMO_39cbed73_6e97_4ab2_bede_dc670e9469c9 a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/metrology#> ;
    rdfs:subPropertyOf emmo:EMMO_b6292331_94af_4f00_976b_ea55960c2f1c ;
    skos:altLabel "measurementUncertainty"@en ;
    skos:prefLabel "uncertainty"@en ;
    emmo:VIMTerm "VIM4: 3.1 measurement uncertainty"@en ;
    emmo:elucidation "A parameter characterising the dispersion of a data value."@en ;
    emmo:note "The uncertainty data property doesn't specify how the uncertainty is defined. For accuracy, use one of the specialised sub-properties."@en,
        "VIM defined 'measurement uncertainty' as a \"parameter characterising the dispersion of the values being attributed to a measurand, based on the information used\"."@en .

emmo:EMMO_3c51ea74_43a4_42d5_953b_fcb43f359c73 a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:isDefinedBy <https://w3id.org/emmo/perspectives/persistence#> ;
