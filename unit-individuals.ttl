emmo:JoulePerMoleKelvin a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_3cb55500_dc5b_4586_bbf3_1d4158afac35 ;
