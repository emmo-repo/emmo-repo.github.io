emmo:Phot a owl:NamedIndividual,
        emmo:EMMO_4000d06d_8594_4263_ba72_5d9440b66c5e,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
