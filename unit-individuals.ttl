emmo:Arcsecond a owl:NamedIndividual,
        emmo:EMMO_6795a4b8_ffd0_4588_a581_a9413fe49cac,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_cdc962d8_f3ea_4764_a57a_c7caa4859179 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedspecialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "ArcSecond"@en,
        "SecondOfArc"@en ;
    skos:prefLabel "Arcsecond"@en ;
    schema:unitCode "D62"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 4.848137e-06 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "″"^^xsd:string ;
    emmo:elucidation """"Arc Second" is a unit of angular measure, also called the `second of arc`, equal to 1/60 arcminute. One arcsecond is a very small angle: there are 1,296,000 in a circle. The SI recommends `double prime` ('') as the symbol for the arcsecond. The symbol has become common in astronomy, where very small angles are stated in milliarcseconds (mas).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/ARCSEC"^^xsd:string ;
    emmo:ucumCode "''"^^xsd:string ;
    emmo:unitSymbol "\\\""^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Minute_of_arc#Symbols.2C_abbreviations_and_subdivisions"^^xsd:string .

