    emmo:illustration "https://raw.githubusercontent.com/emmo-repo/EMMO/1.0.2/doc/figs/Broadcast.png"^^xsd:anyURI .

emmo:EMMO_79fa18f3_6da9_42b9_8cc3_08d9e5c9da87 a owl:ObjectProperty ;
