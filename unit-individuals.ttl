    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Knot per Second"@en ;
    skos:prefLabel "KnotPerSecond"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 5.144444e-01 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """`Knot per Second` is a unit for 'Linear Acceleration' expressed as kt/s.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/KN-PER-SEC"^^xsd:string ;
    emmo:ucumCode "[kn_i].s-1"^^xsd:string,
        "[kn_i]/s"^^xsd:string ;
    emmo:unitSymbol "kn/s"^^xsd:string .

