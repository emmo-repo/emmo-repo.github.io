emmo:Sievert a owl:NamedIndividual,
        emmo:EMMO_847f1d9f_205e_46c1_8cb6_a9e479421f88,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Sievert"@en ;
    schema:unitCode "D13"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Sv"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Sievert"^^xsd:anyURI ;
    emmo:elucidation "SI unit for equivalent doseof ionizing radiation. Sievert is derived from absorbed dose, but takes into account the biological effectiveness of the radiation, which is dependent on the radiation type and energy."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.S05658"^^xsd:string ;
    emmo:note """Although the sievert has the same dimensions as the gray (i.e. joules per kilogram), it measures a different quantity. To avoid any risk of confusion between the absorbed dose and the equivalent dose, the corresponding special units, namely the gray instead of the joule per kilogram for absorbed dose and the sievert instead of the joule per kilogram for the dose equivalent, should be used.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/SV"^^xsd:string ;
    emmo:ucumCode "Sv"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Sievert?oldid=495474333"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Equivalent_dose"^^xsd:string .

emmo:WattPerSquareMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_539d8d92_d3a5_4f46_858f_081fed5b4190 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    rdfs:seeAlso "http://www.efunda.com/glossary/units/units--energy_flux--watt_per_square_meter.cfm"^^xsd:string ;
    skos:altLabel "Watt per Square Metre"@en ;
    skos:prefLabel "WattPerSquareMetre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """"Watt per Square Meter} is a unit of irradiance defined as the power received per area. This is a unit in the category of Energy flux. It is also known as watts per square meter, watt per square metre, watts per square metre, watt/square meter, watt/square metre. This unit is commonly used in the SI unit system. Watt Per Square Meter (W/m²) has a dimension of MT^{-3" where M is mass, and T is time. This unit is the standard SI unit in this category.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/W-PER-M2"^^xsd:string ;
    emmo:ucumCode "W.m-2"^^xsd:string,
        "W/m2"^^xsd:string ;
    emmo:unitSymbol "W/m²"^^xsd:string .

emmo:Weber a owl:NamedIndividual,
        emmo:EMMO_4c49ab58_a6f6_409e_b849_f873ae1dcbee,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Weber"@en ;
    schema:unitCode "WEB"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Wb"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Weber"^^xsd:anyURI ;
    emmo:elucidation "SI unit for magnetic flux."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.W06666"^^xsd:string ;
    emmo:note "The SI unit of magnetic flux. \"Flux\" is the rate (per unit of time) at which something crosses a surface perpendicular to the flow. The weber is a large unit, equal to 10⁸ maxwells, and practical fluxes are usually fractions of one weber. The weber is the magnetic flux which, linking a circuit of one turn, would produce in it an electromotive force of 1 volt if it were reduced to zero at a uniform rate in 1 second. In SI base units, the dimensions of the weber are (kg·m²)/(s²·A). The weber is commonly expressed in terms of other derived units as the Tesla-square meter (T·m²), volt-seconds (V·s), or joules per ampere (J/A)."@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/WB"^^xsd:string ;
    emmo:ucumCode "Wb"^^xsd:string ;
    emmo:wikipediaReference "https://en.wikipedia.org/wiki/Weber_(unit)"^^xsd:anyURI .

emmo:elucidation a owl:AnnotationProperty ;
