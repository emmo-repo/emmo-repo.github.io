    emmo:ucumCode "dyn"^^xsd:string ;
    emmo:unitSymbol "dyn"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Dyne?oldid=494703827"^^xsd:string .

