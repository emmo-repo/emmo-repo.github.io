        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "lumen second"@en ;
    skos:prefLabel "LumenSecond"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """In photometry, the lumen second is the SI derived unit of luminous energy. It is based on the lumen, the SI unit of luminous flux, and the second, the SI base unit of time.  The lumen second is sometimes called the talbot (symbol T).  An older name for the lumen second was the lumberg.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/LM-SEC"^^xsd:string ;
    emmo:ucumCode "lm.s"^^xsd:string ;
    emmo:unitSymbol "lm⋅s"^^xsd:string .

emmo:LunarMass a owl:NamedIndividual,
