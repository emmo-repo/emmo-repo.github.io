    skos:prefLabel "Phot"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+04 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A phot (ph) is a photometric unit of illuminance, or luminous flux through an area. It is not an SI unit, but rather is associated with the older centimetre gram second system of units.  Metric dimensions: illuminance = luminous intensity × solid angle / length.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/PHOT"^^xsd:string ;
    emmo:ucumCode "ph"^^xsd:string ;
    emmo:unitSymbol "ph"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Phot?oldid=477198725"^^xsd:string .

emmo:Pica a owl:NamedIndividual,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b3600e73_3e05_479d_9714_c041c3acf5cc,
        emmo:EMMO_f0404eb3_433e_48af_a50f_67f1a03f5f0c ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Pica"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 4.2333e-03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A pica is a typographic unit of measure corresponding to 1/72 of its respective foot, and therefore to 1/6 of an inch. The pica contains 12 point units of measure. Notably, Adobe PostScript promoted the pica unit of measure that is the standard in contemporary printing, as in home computers and printers. Usually, pica measurements are represented with an upper-case 'P' with an upper-right-to-lower-left virgule (slash) starting in the upper right portion of the 'P' and ending at the lower left of the upright portion of the 'P'; essentially drawing a virgule (/) through a 'P'.  Note that these definitions are different from a typewriter's pica setting, which denotes a type size of ten characters per horizontal inch.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/PCA"^^xsd:string ;
    emmo:ucumCode "[pca]"^^xsd:string ;
    emmo:unitSymbol "pc"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Pica?oldid=458102937"^^xsd:string .

