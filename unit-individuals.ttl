emmo:Decade a owl:NamedIndividual,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_972e01b0_b017_4903_8c05_b7edda958723 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/specialunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Decade"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """One decade is a factor of 10 difference between two numbers (an order of magnitude difference) measured on a logarithmic scale. It is especially useful when referring to frequencies and when describing frequency response of electronic systems, such as audio amplifiers and filters. The factor-of-ten in a decade can be in either direction: so one decade up from 100 Hz is 1000 Hz, and one decade down is 10 Hz. The factor-of-ten is what is important, not the unit used, so 3.14 rad/s is one decade down from 31.4 rad/s.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/DECADE"^^xsd:string ;
    emmo:unitSymbol "dec"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Decade_(log_scale)"^^xsd:string .

emmo:DeciBar a owl:NamedIndividual,
        emmo:EMMO_1181c938_c8f0_4ad6_bc7a_2bfdc0903d29,
        emmo:EMMO_53bd0c90_41c3_46e2_8779_cd2a80f7e18b,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_c6d4a5e0_7e95_44df_a6db_84ee0a8bbc8e ;
