    emmo:elucidation """A measure of the diamagnetic energy, for a Bohr-radius spread around a magnetic axis, per square Tesla.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/J-PER-T2"^^xsd:string ;
