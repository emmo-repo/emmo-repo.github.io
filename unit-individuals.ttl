    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """In the electromagnetic centimeter-gram-second system of units, 'abvolt per centimeter' is the unit of electric field strength.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/V_Ab-PER-CentiM"^^xsd:string ;
    emmo:ucumCode "10.nV.cm-1"^^xsd:string ;
