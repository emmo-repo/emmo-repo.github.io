    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Abhenry is the centimeter-gram-second electromagnetic unit of inductance, equal to one billionth of a henry.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/H_Ab"^^xsd:string ;
    emmo:ucumCode "nH"^^xsd:string ;
    emmo:unitSymbol "abH"^^xsd:string ;
