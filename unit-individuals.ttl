emmo:EMMO_f273529f_9f2c_4877_a94b_5b47590353fc a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/metrology#> ;
    rdfs:subClassOf emmo:EMMO_4a1c73f1_b6f5_4d10_a3a6_5de90bac7cd0 ;
