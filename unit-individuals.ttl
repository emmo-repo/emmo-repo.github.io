    owl:annotatedProperty skos:prefLabel ;
    owl:annotatedSource emmo:EMMO_e7aac247_31d6_4b2e_9fd2_e842b1b7ccac ;
    owl:annotatedTarget "CausalSystem"@en ;
    emmo:etymology "From Latin causa (“reason, sake, cause”), and Ancient Greek σύστημα (sústēma, “musical scale; organized body; whole made of several parts or members”), from σῠν- (sun-, prefix meaning ‘with, together’) + ἵστημι (hístēmi, “to stand”)."@en .

