emmo:EMMO_49267eba_5548_4163_8f36_518d65b583f9 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/perspectives/perspective#> ;
    rdfs:subClassOf emmo:EMMO_c5ddfdba_c074_4aa4_ad6b_1ac4942d300d ;
    skos:prefLabel "Perspective"@en ;
    emmo:elucidation "The class of causal objects that stand for world objects according to a specific representational perspective."@en ;
    emmo:note """This class is the practical implementation of the EMMO pluralistic approach for which the only objective categorization is provided by the Universe individual and all the Quantum individuals.
Between these two extremes, there are several subjective ways to categorize real world objects, each one provide under a 'Perspective' subclass."""@en .

