emmo:MilliArcsecond a owl:NamedIndividual,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_a3a701ed_6f7d_4a10_9aee_dfa1961fc7b7,
        emmo:EMMO_c6d4a5e0_7e95_44df_a6db_84ee0a8bbc8e,
        emmo:EMMO_cdc962d8_f3ea_4764_a57a_c7caa4859179 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedunits-abox#> ;
    skos:altLabel "Milli ArcSecond"@en ;
    skos:prefLabel "MilliArcsecond"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 4.848137e-09 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:EMMO_d4e0a0ab_2f67_4f87_a0db_b544e6dceed4 emmo:Arcsecond ;
    emmo:elucidation """A minute of arc, arcminute, or minute arc (MOA), is a unit of angular measurement equal to one sixtieth (1/60) of one degree (circle/21,600), or π /10,800 radians. In turn, a second of arc or arcsecond is one sixtieth (1/60) of one minute of arc. Since one degree is defined as one three hundred and sixtieth (1/360) of a rotation, one minute of arc is 1/21,600 of a rotation.  the milliarcsecond, abbreviated mas, is used in astronomy.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MilliARCSEC"^^xsd:string ;
    emmo:ucumCode "m''"^^xsd:string ;
    emmo:unitSymbol "mas"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Minute_of_arc"^^xsd:string .

