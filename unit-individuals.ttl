emmo:Abohm a owl:NamedIndividual,
        emmo:EMMO_7610efb8_c7c6_4684_abc1_774783c62472,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:prefLabel "Abohm"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e-09 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """`abohm` is the basic unit of electrical resistance in the emu-cgs system of units. One abohm is equal to 10⁻⁹ ohms in the SI system of units; one abohm is a nano ohm.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/OHM_Ab"^^xsd:string ;
    emmo:ucumCode "nOhm"^^xsd:string ;
    emmo:unitSymbol "abΩ"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Abohm?oldid=480725336"^^xsd:string .

emmo:Absiemens a owl:NamedIndividual,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_86ffe1bb_d457_4948_9e39_35f363b9a9fe,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/otherunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    rdfs:seeAlso "http://wordinfo.info/unit/4266"^^xsd:string ;
    skos:prefLabel "Absiemens"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+09 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """The CGS electromagnetic unit of conductance; one absiemen is the conductance at which a potential of one abvolt forces a current of one abampere; equal to 10⁹ siemens. One siemen is the conductance at which a potential of one volt forces a current of one ampere and named for Karl Wilhem Siemens.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/S_Ab"^^xsd:string ;
    emmo:ucumCode "GS"^^xsd:string ;
    emmo:unitSymbol "aS"^^xsd:string .

emmo:Abtesla a owl:NamedIndividual,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4,
        emmo:EMMO_ec903946_ddc9_464a_903c_7373e0d1eeb5 ;
