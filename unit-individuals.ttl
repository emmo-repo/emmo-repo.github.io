    emmo:EMMO_d4e0a0ab_2f67_4f87_a0db_b544e6dceed4 emmo:Farad ;
    emmo:elucidation """The "microfarad" (symbolized μ F) is a unit of capacitance, equivalent to 0.000001 (10 to the -6th power) farad. The microfarad is a moderate unit of capacitance. In utility alternating-current (AC) and audio-frequency (AF) circuits, capacitors with values on the order of 1 μ F or more are common. At radio frequencies (RF), a smaller unit, the picofarad (pF), is often used.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MicroFARAD"^^xsd:string ;
    emmo:ucumCode "uF"^^xsd:string ;
    emmo:unitSymbol "µF"^^xsd:string .

