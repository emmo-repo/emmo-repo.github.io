emmo:EMMO_eaf4640d_651d_4cbe_a315_3d2dc5df3b35 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/reference/workflow#> ;
    rdfs:subClassOf emmo:EMMO_3e7add3d_e6ed_489a_a796_8e31fef9b490 ;
