emmo:EMMO_593ce968_e1ec_4101_822a_1739ef13fb2b a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/metrology#> ;
    rdfs:subPropertyOf emmo:EMMO_ea67144c_56fd_4312_a4f4_af78edd5eacc ;
    skos:altLabel "expectationValue"@en,
        "expectedValue"@en,
        "meanValue"@en ;
    skos:prefLabel "meanQuantityValue"@en ;
    emmo:elucidation "The probabilistic expected value of an EMMO data entity."@en ;
    emmo:note "The expectation value (or expected value) is the theoretical long-run average outcome of a random variable over many trials, calculated as the sum of all possible values, each weighted by its probability of occurrence. It acts as a probability-weighted mean, representing the center of a probability distribution, denoted as 'E[X]' or 'µ'."@en .

