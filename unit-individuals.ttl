    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.256637e-07 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """A magnetic pole is a unit pole if it exerts a force of one dyne on another pole of equal strength at a distance of 1 cm. The strength of any given pole in cgs units is therefore numerically equal to the force in dynes which it exerts on a unit pole 1 cm away.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/UnitPole"^^xsd:string ;
    emmo:unitSymbol "pole"^^xsd:string .

