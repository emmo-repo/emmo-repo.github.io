        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Planck Force"@en ;
    skos:prefLabel "PlanckForce"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.21027e+44 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """Planck force is the derived unit of force resulting from the definition of the base Planck units for time, length, and mass. It is equal to the natural unit of momentum divided by the natural unit of time.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/PlanckForce"^^xsd:string ;
    emmo:unitSymbol "planckforce"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Planck_force?oldid=493643031"^^xsd:string .

