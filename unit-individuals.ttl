emmo:ElectronVolt a owl:NamedIndividual,
        emmo:EMMO_6795a4b8_ffd0_4588_a581_a9413fe49cac,
        emmo:EMMO_f6070071_d054_4b17_9d2d_f446f7147d0f ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedspecialunits-abox#> ;
    skos:prefLabel "ElectronVolt"@en ;
    schema:unitCode "A53"^^xsd:string ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1.602177e-19 ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "eV"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/page/Electronvolt"^^xsd:string ;
    emmo:definition "The amount of energy gained (or lost) by the charge of a single electron moving across an electric potential difference of one volt."@en ;
    emmo:elucidation """An electron volt (eV) is the energy that an electron gains when it travels through a potential of one volt. You can imagine that the electron starts at the negative plate of a parallel plate capacitor and accelerates to the positive plate, which is at one volt higher potential. Numerically 1 eV approximates 1.6x10⁻¹⁹ joules, where 1 joule is 6.2x10¹⁸ eV. For example, it would take 6.2x10²⁰ eV/sec to light a 100 watt light bulb.

-- QUDT"""@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.E02014"^^xsd:string ;
    emmo:qudtReference "http://qudt.org/vocab/unit/EV"^^xsd:string ;
    emmo:ucumCode "eV"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Electron_volt?oldid=344021738"^^xsd:anyURI .

