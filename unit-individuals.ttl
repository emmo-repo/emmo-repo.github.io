emmo:HertzPerVolt a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_53b10105_52c7_4746_ab73_a5a30bd198e2 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Hertz per Volt"@en ;
    skos:prefLabel "HertzPerVolt"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """In the Hertz per Volt standard the frequency of the note is directly related to the voltage. A pitch of a note goes up one octave when its frequency doubles, meaning that the voltage will have to double for every octave rise. Depending on the footage (octave) selected, nominally one volt gives 1000Hz, two volts 2000Hz and so on. In terms of notes, bottom C would be 0.25 volts, the next C up would be 0.5 volts, then 1V, 2V, 4V, 8V for the following octaves. This system was used mainly by Yamaha and Korg.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/HZ-PER-V"^^xsd:string ;
    emmo:ucumCode "Hz.V-1"^^xsd:string ;
    emmo:unitSymbol "Hz/V"^^xsd:string .

