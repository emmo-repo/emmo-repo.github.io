emmo:EMMO_9f4f4fab_80bc_44e9_81a2_b7ef07ba4011 a owl:Class ;
    rdfs:isDefinedBy <https://w3id.org/emmo/perspectives/semiotics#> ;
    rdfs:subClassOf emmo:EMMO_1783139f_575f_4e41_a409_1e70aceced27 ;
    skos:prefLabel "Learning"@en ;
    emmo:elucidation "A semiosis where the interpreter perceives a referent, that generates the interpretant as interpreter's internal representation.The interpretant is not commmunicated to the external world, but kept in the internal representational space of the interpreter."@en .

emmo:EMMO_a0a2ded8_54e8_408d_a6b0_7fd1b4d7d16d a owl:ObjectProperty ;
