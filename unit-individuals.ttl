emmo:Henry a owl:NamedIndividual,
        emmo:EMMO_585e0ff0_9429_4d3c_b578_58abb1ba21d1,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Henry"@en ;
    schema:unitCode "81"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "H"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Henry"^^xsd:anyURI ;
    emmo:elucidation "SI unit for electrical inductance."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.H02782"^^xsd:string ;
    emmo:note "H = Wb/A = V·s/A = Ω·s"@en,
        """The SI unit of electric inductance. A changing magnetic field induces an electric current in a loop of wire (or in a coil of many loops) located in the field. Although the induced voltage depends only on the rate at which the magnetic flux changes, measured in webers per second, the amount of the current depends also on the physical properties of the coil. A coil with an inductance of one henry requires a flux of one weber for each ampere of induced current. If, on the other hand, it is the current which changes, then the induced field will generate a potential difference within the coil: if the inductance is one henry a current change of one ampere per second generates a potential difference of one volt. The henry is a large unit; inductances in practical circuits are measured in millihenrys (mH) or microhenrys (μH). The unit is named for the American physicist Joseph Henry (1797-1878), one of several scientists who discovered independently how magnetic fields can be used to generate alternating currents.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/H"^^xsd:string ;
    emmo:ucumCode "H"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Henry?oldid=491435978"^^xsd:anyURI .

emmo:Hertz a owl:NamedIndividual,
        emmo:EMMO_515b5579_d526_4842_9e6f_ecc34db6f368,
        emmo:EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siunits-abox#> ;
    skos:prefLabel "Hertz"@en ;
    schema:unitCode "HTZ"^^xsd:string ;
    emmo:EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Hz"^^xsd:string ;
    emmo:dbpediaReference "http://dbpedia.org/resource/Hertz"^^xsd:anyURI ;
    emmo:elucidation "SI unit for frequence."@en ;
    emmo:iupacReference "https://doi.org/10.1351/goldbook.H02785"^^xsd:string ;
    emmo:note """The hertz (symbol Hz) is the SI unit of frequency defined as the number of cycles per second of a periodic phenomenon. One of its most common uses is the description of the sine wave, particularly those used in radio and audio applications, such as the frequency of musical tones. The word "hertz" is named for Heinrich Rudolf Hertz, who was the first to conclusively prove the existence of electromagnetic waves.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/HZ"^^xsd:string ;
    emmo:ucumCode "Hz"^^xsd:string .

emmo:MolePerLitre a owl:NamedIndividual,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_ac19c801_bead_4730_8b8c_50020eec45ec,
        emmo:EMMO_e9348e5b_af4f_4898_bbfe_c4583cf44b80 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Mole Per Litre"@en ;
    skos:prefLabel "MolePerLitre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """SI base unit mol divided by the unit litre

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MOL-PER-L"^^xsd:string ;
    emmo:ucumCode "mol.L-1"^^xsd:string,
        "mol/L"^^xsd:string ;
