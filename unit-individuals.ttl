    emmo:ucumCode "kBy"^^xsd:string ;
    emmo:unitSymbol "kB"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Byte?oldid=493588918"^^xsd:string .

