emmo:AmpereHour a owl:NamedIndividual,
        emmo:EMMO_ab79e92b_5377_454d_be06_d61b50db295a,
        emmo:EMMO_ac19c801_bead_4730_8b8c_50020eec45ec ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/siacceptedunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    rdfs:seeAlso "http://www.oxfordreference.com/view/10.1093/acref/9780199233991.001.0001/acref-9780199233991-e-86"^^xsd:string ;
    skos:altLabel "Ampere Hour"@en ;
    skos:prefLabel "AmpereHour"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 3.6e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """`Ampere hour` is a practical unit of electric charge equal to the charge flowing in one hour through a conductor passing one ampere. An ampere-hour or amp-hour (symbol Ah, AHr,  A · h, A h) is a unit of electric charge, with sub-units milliampere-hour (mAh) and milliampere second (mAs). One ampere-hour is equal to 3600 coulombs (ampere-seconds), the electric charge transferred by a steady current of one ampere for one hour. The ampere-hour is frequently used in measurements of electrochemical systems such as electroplating and electrical batteries. The commonly seen milliampere-hour (mAh or mA · h) is one-thousandth of an ampere-hour (3.6  coulombs).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/A-HR"^^xsd:string ;
    emmo:ucumCode "A.h"^^xsd:string ;
    emmo:unitSymbol "A⋅h"^^xsd:string ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Ampere-hour"^^xsd:string .

emmo:AmperePerMetre a owl:NamedIndividual,
        emmo:EMMO_1273eb34_de48_43a9_925f_104110469dd2,
        emmo:EMMO_e6b83139_ba92_4fbd_a8b2_c8dde55844a1 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/coherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Ampere per Metre"@en ;
    skos:prefLabel "AmperePerMetre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+00 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """ is the SI unit of magnetic field strength. One ampere per meter is equal to π/250 oersteds (12.566  371 millioersteds) in CGS units. The ampere per meter is also the SI unit of "magnetization" in the sense of magnetic dipole moment per unit volume; in this context 1 A/m = 0.001 emu per cubic centimeter.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/A-PER-M"^^xsd:string ;
    emmo:ucumCode "A.m-1"^^xsd:string,
        "A/m"^^xsd:string ;
    emmo:unitSymbol "A/m"^^xsd:string .

emmo:AmperePerMilliMetre a owl:NamedIndividual,
        emmo:EMMO_60b78cc3_6011_4134_95ab_956f56d4bdc1,
        emmo:EMMO_e6b83139_ba92_4fbd_a8b2_c8dde55844a1 ;
    rdfs:isDefinedBy <https://w3id.org/emmo/disciplines/units/noncoherentsiunits-abox#>,
        "http://qudt.org/2.1/vocab/unit"^^xsd:string ;
    skos:altLabel "Ampere Per Millimetre"@en ;
    skos:prefLabel "AmperePerMilliMetre"@en ;
    emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf 1e+03 ;
    emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd 0e+00 ;
    emmo:elucidation """SI base unit ampere divided by the 0.001-fold of the SI base unit metre

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/A-PER-MilliM"^^xsd:string ;
    emmo:ucumCode "A.mm-1"^^xsd:string,
        "A/mm"^^xsd:string ;
    emmo:unitSymbol "A/mm"^^xsd:string .

