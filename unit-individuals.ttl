    skos:altLabel "hasSpatialDirectPart"@en ;
    skos:prefLabel "hasSpatialTile"@en ;
    emmo:elucidation "A relation between the whole and one of its tiles, where the tile is only spatially connected with the other tiles forming the tessellation."^^xsd:string .

