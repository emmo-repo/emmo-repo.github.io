ns1:EMMO_e4281979_2b07_4a43_a772_4903fb3696fe a owl:Class ;
    rdfs:label "Dust"@en ;
    rdfs:comment "A suspension of fine particles in the atmosphere."@en ;
    rdfs:subClassOf ns1:EMMO_d4f37e32_16ae_4cc6_b4cd_fd896b2449c4 ;
