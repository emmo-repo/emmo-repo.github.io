    skos:prefLabel "Gel"@en ;
    ns1:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "A soft, solid or solid-like colloid consisting of two or more components, one of which is a liquid, present in substantial quantity."@en .

